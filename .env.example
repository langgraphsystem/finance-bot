# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-app.railway.app/webhook

# === Database (Supabase) ===
# Paste Supabase connection string as-is — app auto-converts to asyncpg
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...
XAI_API_KEY=xai-...

# === Google Maps & YouTube (detailed mode) ===
GOOGLE_MAPS_API_KEY=AIza...
YOUTUBE_API_KEY=AIza...

# === Langfuse (Observability) ===
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3000

# === Mem0 ===
MEM0_API_KEY=
MEM0_BASE_URL=

# === Supabase MCP (optional, for advanced analytics) ===
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=your-project-ref

# === App Settings ===
APP_ENV=development
LOG_LEVEL=INFO
HEALTH_SECRET=change-me
RATE_LIMIT_PER_MINUTE=30
FF_LOCALE_V2_READ=false
FF_LOCALE_V2_WRITE=false
FF_REMINDER_DISPATCH_V2=false

# === Release Ops / Controlled Rollout ===
RELEASE_ROLLOUT_NAME=finance-bot-canary
RELEASE_ROLLOUT_PERCENT=0
RELEASE_SHADOW_MODE=true
RELEASE_HEALTH_LOGGING=true
RELEASE_DEFAULT_COHORT=normal
RELEASE_INTERNAL_USER_IDS=
RELEASE_TRUSTED_USER_IDS=
RELEASE_BETA_USER_IDS=
RELEASE_VIP_USER_IDS=
RELEASE_SENSITIVE_ROLES=accountant,assistant
RELEASE_OPS_ENABLED=false
RELEASE_OPS_BASE_URL=https://your-app.railway.app
RELEASE_OPS_REVIEWER=release-ops
RELEASE_OPS_APPLY_WEEKLY_REVIEW=false
RELEASE_OPS_WEEKLY_REVIEW_CRON=0 13 * * 1
RELEASE_OPS_CYCLE_CRON=0 14 * * *

# === Voice Pilot (OpenAI Realtime + Twilio) ===
VOICE_ENABLED=false
VOICE_PUBLIC_BASE_URL=https://your-app.railway.app
VOICE_WS_BASE_URL=wss://your-app.railway.app
VOICE_OPENAI_REALTIME_MODEL=gpt-realtime-1.5
VOICE_OPENAI_REALTIME_FALLBACK_MODEL=gpt-realtime-mini
VOICE_OPENAI_REALTIME_VOICE=marin
VOICE_DEFAULT_OWNER_TELEGRAM_ID=
VOICE_DEFAULT_OWNER_NAME=the owner
VOICE_DEFAULT_BUSINESS_NAME=your business
VOICE_DEFAULT_BUSINESS_HOURS=Mon-Fri 9-5
VOICE_DEFAULT_SERVICES=general assistance
VOICE_ALLOW_OUTBOUND=false
VOICE_ALLOW_WRITE_TOOLS=false
VOICE_RECEPTIONIST_ONLY=true
VOICE_FORCE_CALLBACK_MODE=true
VOICE_VERIFICATION_TTL_SECONDS=300
VOICE_VERIFICATION_CODE_LENGTH=6
