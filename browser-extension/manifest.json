{
  "manifest_version": 3,
  "name": "Finance Bot — Session Saver",
  "version": "1.0",
  "description": "Save browser sessions for Finance Bot automation",
  "permissions": ["cookies", "activeTab", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
